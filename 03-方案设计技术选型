def forecast(request: ForecastRequest) -> ForecastResponse:
    trace = new_trace(request)
    
    # === Step 1: 意图解析 ===
    intent = parse_intent(request.text)                      # 🔴 LLM ~300 tokens
    # 解析结果包含: site, date, time_window(T+0/T+N), 
    # framework(F1-F6), dimensions[], events[]
    
    # === Step 2: 取数（DataAdapter 统一拉取） ===
    evidence = build_blackboard(intent, trace)               # 🟢 拉取 H1-H4, P1-P4, M0
    evidence += parse_date_events(intent.target_date)        # 🟢 日期事件自动解析
    
    # === Step 3: 用户输入门禁（对齐手册：维度细分必须用户提供） ===
    gate = user_input_gate.check(intent.framework, intent.user_inputs)
    if not gate.passed:
        return ask_user_for_input(gate.prompt)               # 🟢 交互式补全
    
    # === Step 4: M1 变体路由（对齐手册5种变体） ===
    m1_variant = m1_router.select_variant(                   # 🟢 自动选择
        time_window=intent.time_window,  # T+0 或 T+N
        evidence=evidence,
    )
    
    # === Step 5: 框架分解（对齐手册 F1-F6 子部件分解） ===
    sub_parts = framework_decomposer.decompose(              # 🟢 框架→子部件
        framework=intent.framework,
        user_inputs=intent.user_inputs,
    )
    
    # === Step 6: 难度评估 + 动态团队选择 ===
    difficulty = score_difficulty(intent, evidence)          # 🟢 四维难度评分
    team = select_team_with_thompson_sampling(               # 🟢 Thompson Sampling
        intent=intent, evidence=evidence,
        difficulty=difficulty, registry=skill_registry,
    )
    
    # === Step 7: 事件编码（有非结构化事件时） ===
    evidence = event_encode(evidence)                        # 🔴 LLM ~800 tokens
    
    # === Step 8: 并行执行（每个子部件 × 指派方法） ===
    claims = []
    for part in sub_parts:
        part_claims = run_skills_parallel(                   # 🟢 纯代码执行
            team=team,
            sub_part=part,
            m1_variant=m1_variant,
            evidence=evidence,
            timeout=budget_for(difficulty),
            trace=trace,
        )
        claims.extend(part_claims)
    
    # === Step 9: 框架合并（子部件结果按加/减合并） ===
    merged = framework_decomposer.merge(claims)              # 🟢 子部件加总
    
    # === Step 10: 维度下钻（如用户指定了维度） ===
    if intent.dimensions:
        merged = apply_dimension_splits(                     # 🟢 用户提供的比例
            merged, intent.dimensions, intent.user_inputs)
    
    # === Step 11: 质量门禁 + 分歧检测 ===
    merged = quality_gate(merged)                            # 🟢 规则校验
    disagreement = calc_disagreement(claims, intent)         # 🟢 纯计算
    if disagreement.requires_debate:
        claims = bounded_debate(claims, evidence,            # 🔴 LLM ~1500
                                max_rounds=debate_rounds(difficulty))
    
    # === Step 12: Bayesian Fusion + Conformal Calibration ===
    fused = bayesian_fusion(claims)                          # 🟢 纯数学
    calibrated = conformal_calibrate(fused,                  # 🟢 纯统计
        bucket=scenario_bucket(intent, evidence))
    
    # === Step 13: HITL 门禁 ===
    hitl = hitl_gate(calibrated, disagreement,               # 🟢 阈值比较
                     business_impact=intent.impact)
    if hitl.required:
        return send_to_human_review(calibrated, claims, evidence, trace)
    
    # === Step 14: 发布 + 记录 ===
    publish_forecast(calibrated, trace)                      # 🟢 纯代码
    return build_response(calibrated, claims, trace)
```

